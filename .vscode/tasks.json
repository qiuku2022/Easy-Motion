{
  "version": "2.0.0",
  "options": {
    "env": {
      "PYTHONIOENCODING": "utf-8",
      "PYTHONUTF8": "1"
    }
  },
  "tasks": [
    {
      "label": "free: electron cdp",
      "type": "process",
      "command": "node",
      "args": ["${workspaceFolder}/apps/electron/scripts/free-cdp-port.cjs"],
      "options": {
        "cwd": "${workspaceFolder}/apps/electron",
        "env": { "ELECTRON_CDP_PORT": "9333" }
      },
      "presentation": { "reveal": "never", "panel": "dedicated", "close": true },
      "problemMatcher": []
    },
    {
      "label": "wait: electron cdp",
      "type": "process",
      "command": "node",
      "args": ["${workspaceFolder}/apps/electron/scripts/wait-cdp.cjs"],
      "options": {
        "cwd": "${workspaceFolder}/apps/electron",
        "env": { "ELECTRON_CDP_PORT": "9333" }
      },
      "presentation": { "reveal": "never", "panel": "dedicated", "close": true },
      "problemMatcher": []
    },
    {
      "label": "ensure: vite",
      "type": "process",
      "command": "node",
      "args": ["${workspaceFolder}/apps/electron/scripts/ensure-vite-for-debug.cjs"],
      "options": { "cwd": "${workspaceFolder}/apps/electron" },
      "presentation": { "reveal": "never", "panel": "dedicated", "close": true },
      "problemMatcher": []
    },
    {
      "label": "debug: prepare",
      "type": "process",
      "command": "node",
      "args": ["${workspaceFolder}/apps/electron/scripts/debug-prepare.cjs"],
      "options": {
        "cwd": "${workspaceFolder}/apps/electron",
        "env": { "ELECTRON_CDP_PORT": "9333" }
      },
      "presentation": { "reveal": "never", "panel": "dedicated", "close": true },
      "problemMatcher": []
    },
    {
      "label": "debug: cleanup",
      "type": "process",
      "command": "node",
      "args": ["${workspaceFolder}/apps/electron/scripts/cleanup-debug-processes.cjs"],
      "options": {
        "cwd": "${workspaceFolder}/apps/electron",
        "env": {
          "ELECTRON_CDP_PORT": "9333",
          "EASY_MOTION_PYTHON_PORT": "8001"
        }
      },
      "presentation": { "reveal": "never", "panel": "dedicated", "close": true },
      "problemMatcher": []
    },
    {
      "label": "debug: cleanup (full stack)",
      "type": "process",
      "command": "node",
      "args": ["${workspaceFolder}/apps/electron/scripts/cleanup-debug-processes.cjs"],
      "options": {
        "cwd": "${workspaceFolder}/apps/electron",
        "env": {
          "ELECTRON_CDP_PORT": "9333",
          "EASY_MOTION_PYTHON_PORT": "8001",
          "EASY_MOTION_CLEANUP_PYTHON": "1"
        }
      },
      "presentation": { "reveal": "never", "panel": "dedicated", "close": true },
      "problemMatcher": []
    },
    {
      "label": "pnpm: dev",
      "type": "shell",
      "command": "pnpm",
      "args": ["dev"],
      "options": { "cwd": "${workspaceFolder}" },
      "group": { "kind": "build", "isDefault": true },
      "presentation": { "reveal": "always", "panel": "dedicated", "group": "dev" },
      "problemMatcher": []
    },
    {
      "label": "pnpm: dev:all",
      "type": "shell",
      "command": "pnpm",
      "args": ["dev:all"],
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "dedicated", "group": "dev" },
      "problemMatcher": []
    },
    {
      "label": "pnpm: dev:electron",
      "type": "shell",
      "command": "pnpm",
      "args": ["dev:electron"],
      "options": { "cwd": "${workspaceFolder}" },
      "dependsOn": ["debug: prepare"],
      "dependsOrder": "sequence",
      "presentation": { "reveal": "always", "panel": "dedicated", "group": "dev" },
      "problemMatcher": []
    },
    {
      "label": "pnpm: test",
      "type": "shell",
      "command": "pnpm",
      "args": ["test"],
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "dedicated" },
      "problemMatcher": []
    },
    {
      "label": "pnpm: lint",
      "type": "shell",
      "command": "pnpm",
      "args": ["lint"],
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": ["$eslint-stylish"]
    },
    {
      "label": "uv: install python deps",
      "type": "shell",
      "windows": {
        "command": "${workspaceFolder}\\apps\\python\\.venv\\Scripts\\pip.exe",
        "args": ["install", "-r", "requirements.txt"],
        "options": { "cwd": "${workspaceFolder}\\apps\\python" }
      },
      "linux": {
        "command": "${workspaceFolder}/apps/python/.venv/bin/pip",
        "args": ["install", "-r", "requirements.txt"],
        "options": { "cwd": "${workspaceFolder}/apps/python" }
      },
      "osx": {
        "command": "${workspaceFolder}/apps/python/.venv/bin/pip",
        "args": ["install", "-r", "requirements.txt"],
        "options": { "cwd": "${workspaceFolder}/apps/python" }
      },
      "presentation": { "reveal": "always" },
      "problemMatcher": []
    }
  ]
}
