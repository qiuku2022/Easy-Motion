{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "pnpm: build:main",
      "type": "shell",
      "command": "pnpm",
      "args": ["build:main"],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "silent",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "pnpm: build",
      "type": "shell",
      "command": "pnpm",
      "args": ["build"],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "silent",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "pnpm: dev:electron",
      "type": "shell",
      "command": "pnpm",
      "args": ["dev:electron"],
      "group": "build",
      "isBackground": true,
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": {
        "pattern": {
          "regexp": ".",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*electron-vite dev.*",
          "endsPattern": "^.*(ready|Compiled|Dev server running).*"
        }
      }
    }
  ]
}
