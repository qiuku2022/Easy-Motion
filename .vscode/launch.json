{
  "version": "0.2.0",
  "inputs": [
    {
      "id": "remotionDebugPort",
      "type": "promptString",
      "description": "Remotion 预览端口（见启动日志 previewUrl，默认 5174）",
      "default": "5174"
    },
    {
      "id": "remotionWebRoot",
      "type": "promptString",
      "description": "当前项目的 remotion 目录（含 preview.html、src/）",
      "default": "${workspaceFolder}/apps/electron/resources/templates/default-project/subprojects/default/remotion"
    }
  ],
  "configurations": [
    {
      "name": "▸ Electron Main",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/apps/electron",
      "preLaunchTask": "debug: prepare",
      "postDebugTask": "debug: cleanup",
      "runtimeExecutable": "${workspaceFolder}/apps/electron/node_modules/.bin/electron",
      "windows": {
        "runtimeExecutable": "${workspaceFolder}/apps/electron/node_modules/.bin/electron.cmd"
      },
      "program": "${workspaceFolder}/apps/electron/src/main/index.js",
      "args": ["--remote-debugging-port=9333"],
      "outputCapture": "std",
      "console": "integratedTerminal",
      "sourceMaps": true,
      "timeout": 120000,
      "skipFiles": [
        "<node_internals>/**",
        "${workspaceFolder}/apps/electron/node_modules/**"
      ],
      "env": {
        "ELECTRON_ENABLE_LOGGING": "1",
        "NODE_ENV": "development",
        "ELECTRON_RENDERER_URL": "http://127.0.0.1:5173",
        "ELECTRON_CDP_PORT": "9333"
      },
      "presentation": { "hidden": true }
    },
    {
      "name": "▸ Attach React Renderer",
      "type": "chrome",
      "request": "attach",
      "preLaunchTask": "wait: electron cdp",
      "port": 9333,
      "urlFilter": "http://127.0.0.1:5173/*",
      "webRoot": "${workspaceFolder}/apps/electron/src/renderer/src",
      "timeout": 120000,
      "sourceMaps": true,
      "sourceMapPathOverrides": {
        "webpack:///*": "${webRoot}/*",
        "/src/*": "${webRoot}/*",
        "/@fs/*": "/*",
        "/@/*": "${webRoot}/*"
      },
      "presentation": { "hidden": true }
    },
    {
      "name": "Python: FastAPI",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": ["main:app", "--host", "127.0.0.1", "--port", "8001", "--reload"],
      "cwd": "${workspaceFolder}/apps/python",
      "python": "${command:python.interpreterPath}",
      "justMyCode": true,
      "env": {
        "PYTHONUNBUFFERED": "1",
        "PYTHONIOENCODING": "utf-8",
        "PYTHONUTF8": "1"
      },
      "console": "integratedTerminal",
      "postDebugTask": "debug: cleanup (full stack)",
      "presentation": { "group": "components", "order": 1 }
    },
    {
      "name": "React: Vite (Chrome)",
      "type": "chrome",
      "request": "launch",
      "url": "http://127.0.0.1:5173",
      "webRoot": "${workspaceFolder}/apps/electron/src/renderer/src",
      "preLaunchTask": "debug: prepare",
      "postDebugTask": "debug: cleanup",
      "sourceMaps": true,
      "sourceMapPathOverrides": {
        "/src/*": "${webRoot}/*",
        "/@/*": "${webRoot}/*"
      },
      "presentation": { "group": "components", "order": 2 }
    },
    {
      "name": "Remotion Preview (attach)",
      "type": "chrome",
      "request": "attach",
      "port": "${input:remotionDebugPort}",
      "webRoot": "${input:remotionWebRoot}",
      "timeout": 120000,
      "sourceMaps": true,
      "sourceMapPathOverrides": {
        "/src/*": "${input:remotionWebRoot}/src/*",
        "/@fs/*": "/*"
      },
      "presentation": { "group": "components", "order": 3 }
    }
  ],
  "compounds": [
    {
      "name": "EasyMotion: Dev",
      "configurations": ["▸ Electron Main"],
      "stopAll": true,
      "presentation": { "group": "main", "order": 1 }
    },
    {
      "name": "EasyMotion: Dev + React 断点",
      "configurations": ["▸ Electron Main", "▸ Attach React Renderer"],
      "stopAll": true,
      "presentation": { "group": "main", "order": 2 }
    },
    {
      "name": "EasyMotion: Full Stack",
      "configurations": ["Python: FastAPI", "▸ Electron Main"],
      "stopAll": true,
      "presentation": { "group": "main", "order": 3 }
    }
  ]
}
