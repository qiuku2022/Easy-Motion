{
  "version": "1.0",
  "description": "Remotion Code Agent 评估任务集。deterministic 任务用 test-remotion-code-agent-eval.js 离线验证。",
  "fixture": {
    "subprojectPath": "subprojects/default",
    "packageJson": {
      "dependencies": {
        "remotion": "4.0.269",
        "react": "^18.3.1"
      }
    }
  },
  "snippets": {
    "simpleFill": "import React from \"react\";\nimport { AbsoluteFill } from \"remotion\";\n\nexport const SimpleFill: React.FC = () => {\n  return <AbsoluteFill style={{ backgroundColor: \"#ff0000\" }} />;\n};\n",
    "redBg": "import React from \"react\";\nimport { AbsoluteFill, useCurrentFrame, interpolate } from \"remotion\";\n\nexport type RedBgProps = { color?: string };\n\nexport const RedBg: React.FC<RedBgProps> = ({ color = \"#ff0000\" }) => {\n  const frame = useCurrentFrame();\n  const opacity = interpolate(frame, [0, 30], [0, 1], { extrapolateRight: \"clamp\" });\n  return <AbsoluteFill style={{ backgroundColor: color, opacity }} />;\n};\n"
  },
  "tasks": [
    {
      "id": "rc-01",
      "name": "写入最简 AbsoluteFill 组件",
      "mode": "deterministic",
      "userPrompt": "写入 components/custom/SimpleFill.tsx",
      "steps": [
        {
          "op": "writeRemotionFile",
          "args": {
            "relativePath": "components/custom/SimpleFill.tsx",
            "content": "$snippet:simpleFill"
          }
        }
      ],
      "assertions": [
        { "type": "fileExists", "path": "components/custom/SimpleFill.tsx" },
        { "type": "fileContentIncludes", "path": "components/custom/SimpleFill.tsx", "includes": "SimpleFill" }
      ]
    },
    {
      "id": "rc-02",
      "name": "registerCustomComponent + timeline animation clip",
      "mode": "deterministic",
      "userPrompt": "注册 RedBg 并加到时间线",
      "steps": [
        {
          "op": "registerCustomComponent",
          "args": {
            "componentName": "RedBg",
            "content": "$snippet:redBg",
            "parameters": { "color": "#ff0000" },
            "applyToTimeline": true
          },
          "saveAs": "clipId"
        }
      ],
      "assertions": [
        { "type": "fileExists", "path": "components/custom/RedBg.tsx" },
        { "type": "registryContains", "components": ["RedBg"] },
        { "type": "animationClipCount", "min": 1 },
        { "type": "clipSource", "clipId": "$clipId", "path": "component", "equals": "RedBg" }
      ]
    },
    {
      "id": "rc-03",
      "name": "patch 修改 props 默认值",
      "mode": "deterministic",
      "userPrompt": "把 RedBg 默认色改成蓝色",
      "setupSteps": [
        {
          "op": "registerCustomComponent",
          "args": {
            "componentName": "RedBg",
            "content": "$snippet:redBg",
            "applyToTimeline": false
          }
        }
      ],
      "steps": [
        {
          "op": "patchRemotionFile",
          "args": {
            "relativePath": "components/custom/RedBg.tsx",
            "search": "color = \"#ff0000\"",
            "replace": "color = \"#0000ff\""
          }
        }
      ],
      "assertions": [
        {
          "type": "fileContentIncludes",
          "path": "components/custom/RedBg.tsx",
          "includes": "#0000ff"
        }
      ]
    },
    {
      "id": "rc-04",
      "name": "越界写入被拒绝",
      "mode": "deterministic",
      "userPrompt": "尝试写 MainSequence",
      "steps": [
        {
          "op": "expectWriteRejected",
          "args": {
            "relativePath": "components/MainSequence.tsx",
            "content": "$snippet:simpleFill",
            "errorPattern": "E2410"
          }
        }
      ],
      "assertions": [{ "type": "remotionUnchanged" }]
    },
    {
      "id": "rc-05",
      "name": "custom-registry 双组件注册",
      "mode": "deterministic",
      "userPrompt": "注册两个 custom 组件",
      "setupSteps": [
        {
          "op": "registerCustomComponent",
          "args": {
            "componentName": "RedBg",
            "content": "$snippet:redBg",
            "applyToTimeline": false
          }
        }
      ],
      "steps": [
        {
          "op": "registerCustomComponent",
          "args": {
            "componentName": "SimpleFill",
            "content": "$snippet:simpleFill",
            "applyToTimeline": false
          }
        }
      ],
      "assertions": [
        { "type": "registryContains", "components": ["RedBg", "SimpleFill"] }
      ]
    },
    {
      "id": "rc-06",
      "name": "listRemotionFiles 含 custom 目录",
      "mode": "deterministic",
      "userPrompt": "列出 remotion 文件",
      "setupSteps": [
        {
          "op": "writeRemotionFile",
          "args": {
            "relativePath": "components/custom/Foo.tsx",
            "content": "$snippet:simpleFill"
          }
        }
      ],
      "steps": [
        { "op": "listRemotionFiles", "args": { "maxDepth": 4 }, "saveAs": "files" }
      ],
      "assertions": [
        {
          "type": "fileListIncludes",
          "var": "files",
          "includes": "components/custom/Foo.tsx"
        }
      ]
    }
  ]
}
