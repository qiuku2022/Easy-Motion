# EasyMotion 环境变量配置（开发环境）
# 复制此文件为 .env 并填入实际值
# .env 已加入 .gitignore，不会提交到版本控制

# ============================================
# Electron 开发模式
# ============================================
NODE_ENV=development
ELECTRON_ENABLE_LOGGING=1

# ============================================
# Python 服务
# ============================================
PYTHON_PORT=8000
PYTHON_DEBUG=1

# ============================================
# LLM API（可选，用于快速测试）
# ============================================
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-...

# ============================================
# 代理设置（如需要）
# ============================================
# HTTP_PROXY=http://proxy:8080
# HTTPS_PROXY=http://proxy:8080
# NO_PROXY=localhost,127.0.0.1
