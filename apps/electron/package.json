{
  "name": "@easymotion/electron",
  "version": "0.1.0",
  "private": true,
  "main": "src/main/index.js",
  "scripts": {
    "dev": "concurrently -k \"pnpm dev:renderer\" \"pnpm dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on http://127.0.0.1:5173 && cross-env ELECTRON_RENDERER_URL=http://127.0.0.1:5173 electron .",
    "dev:legacy": "electron . --legacy-ui",
    "build:renderer": "vite build",
    "test:m1": "node scripts/test-file-service.js && node scripts/test-project-service.js",
    "test:m2": "node scripts/test-timeline-schema.js && node scripts/test-generator.js && node scripts/test-timeline-service.js && node scripts/test-remotion-project.js",
    "test:m3": "node scripts/test-generator.js",
    "test": "pnpm test:m1 && pnpm test:m2 && pnpm test:m3"
  },
  "dependencies": {
    "@easymotion/shared": "workspace:*",
    "clsx": "^2.1.1",
    "electron": "^42.3.1",
    "lucide-react": "^0.511.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.6.0",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.5.2",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.0",
    "cross-env": "^7.0.3",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vite": "^5.4.19",
    "wait-on": "^8.0.3"
  }
}
