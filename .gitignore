# Dependencies
node_modules/

# Build & bundler outputs
dist/
out/
release/
.cache/
coverage/
*.tsbuildinfo

# Vite / tooling caches
**/.vite/
.eslintcache

# Logs
*.log

# Environment & secrets
.env
.env.*
!.env.example
secrets.json
*.pem
*.key

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
.Python
apps/python/.build-bundle/
apps/electron/resources/python/**
!apps/electron/resources/python/.gitkeep

# IDE / editor (share team debug config only)
.DS_Store
Thumbs.db
desktop.ini
.idea/
*.suo
*.user
*.swp
*~

.vscode/*
!.vscode/launch.json
!.vscode/tasks.json
!.vscode/settings.json
!.vscode/extensions.json

# Cursor: ignore local agent state; committed skills live under .cursor/skills/
.cursor/*
!.cursor/skills/
!.cursor/skills/**

# npx skills 管理目录（不提交；更新后运行 pnpm skills:sync）
.agents/

# Local-only notes (agent plans, scratch — not for commit)
.local/

# Runtime / local app data
tmp/
temp/
*.pid

# ui-ux-pro-max --persist 在仓库根目录生成的设计快照（权威：docs/design-system/）
/design-system/

# Remotion / preview artifacts inside template projects
**/remotion/.cache/
**/remotion/build/
**/remotion/.easymotion/

# Preset animated WebP thumbnails (large; generate locally — see README)
apps/electron/resources/presets/thumbnails/*.webp
apps/electron/src/renderer/public/presets/thumbnails/*.webp
