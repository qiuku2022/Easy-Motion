# Dependencies
node_modules/
**/node_modules/

# Build & bundler outputs
dist/
build/
out/
release/
dist-electron/
.turbo/
.cache/
coverage/
*.tsbuildinfo

# Vite / tooling caches (may live under node_modules)
**/.vite/
.eslintcache

# Logs
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment & secrets
.env
.env.*
!.env.example
secrets.json
*.pem
*.key

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
.Python
# PyInstaller / bundle-for-electron 中间产物
apps/python/.build-bundle/
# 打进安装包的 venv（build:python 生成，体积大）
apps/electron/resources/python/**
!apps/electron/resources/python/.gitkeep

# IDE / editor (share team debug config only)
.DS_Store
Thumbs.db
desktop.ini
.idea/
*.suo
*.user
*.swp
*~

.vscode/*
!.vscode/launch.json
!.vscode/tasks.json
!.vscode/settings.json
!.vscode/extensions.json

# Cursor: optional project skills; ignore local agent state
.cursor/*
!.cursor/skills/
!.cursor/skills/**
.cursor/skills/**/__pycache__/

# Local-only notes (agent plans, scratch — not for commit)
.local/

# Runtime / local app data
tmp/
temp/
*.pid
.omo/

# ui-ux-pro-max --persist 在仓库根目录生成的设计快照（权威：docs/design-system/）
/design-system/

# Remotion / preview artifacts inside template projects
**/remotion/.cache/
**/remotion/build/
**/remotion/.easymotion/

# Preset animated WebP thumbnails (large; generate locally — see README)
apps/electron/resources/presets/thumbnails/*.webp
apps/electron/src/renderer/public/presets/thumbnails/*.webp
