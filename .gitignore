# EasyMotion - 仅上传文档
# 此配置确保只有 docs/ 目录下的文档被提交到 GitHub

# ─────────────────────────────────────────
# 1. 忽略所有文件（默认规则）
# ─────────────────────────────────────────
*

# ─────────────────────────────────────────
# 2. 不忽略根目录下的必要文件
# ─────────────────────────────────────────
!.gitignore
!README.md
!LICENSE*

# ─────────────────────────────────────────
# 3. 不忽略 docs/ 目录及其所有内容
# ─────────────────────────────────────────
!docs/
!docs/**

# ─────────────────────────────────────────
# 4. 确保 docs 内部的隐藏文件也被跟踪
# ─────────────────────────────────────────
!docs/**/.nojekyll

# ─────────────────────────────────────────
# 5. 明确忽略常见的非文档文件（双重保险）
# ─────────────────────────────────────────
# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
package-lock.json
yarn.lock
pnpm-lock.yaml

# 构建产物
dist/
build/
out/
*.asar

# Electron
release/

# Python
__pycache__/
*.py[cod]
*$py.class
.Python
env/
venv/
ENV/
.venv

# 日志
tmp/
temp/
*.tmp
*.log

# 编辑器
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# OpenCode 配置
.opencode/
.omo/

# 环境变量
.env
.env.local
.env.*.local

# 其他项目文件（只保留文档）
*.ts
*.tsx
*.js
*.jsx
*.json
*.py
*.css
*.scss
*.less
*.html
*.config.*
*.config
tsconfig.json
vite.config.*
electron-builder.yml
next.config.*
tailwind.config.*
postcss.config.*
.eslintrc*
.prettierrc*
