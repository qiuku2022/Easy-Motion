{
  "name": "easymotion",
  "version": "0.1.0",
  "private": true,
  "description": "LLM-driven desktop app for creating Remotion animations via natural language",
  "scripts": {
    "dev": "concurrently -n electron,python -c blue,green \"pnpm dev:electron\" \"pnpm dev:python\"",
    "dev:electron": "pnpm --filter @easymotion/electron dev",
    "dev:python": "cd apps/python && python3 main.py || python main.py",
    "build": "pnpm --filter @easymotion/shared build && pnpm --filter @easymotion/electron build",
    "build:renderer": "pnpm --filter @easymotion/electron build:renderer",
    "build:main": "pnpm --filter @easymotion/shared build && pnpm --filter @easymotion/electron build:main",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "pnpm -r --parallel run typecheck",
    "test": "pnpm -r --parallel run test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "rimraf dist && pnpm -r --parallel run clean",
    "clean:all": "rimraf node_modules && pnpm -r --parallel run clean:all"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "eslint": "^9.0.0",
    "prettier": "^3.2.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}
